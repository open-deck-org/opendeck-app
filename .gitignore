# dependencies
node_modules/

# vendored browser libs (regenerated by postinstall)
www/vendor/

# collected build outputs (binaries) — keep the folder's README, ignore artifacts
dist/*
!dist/README.md

# local xcodebuild derivedDataPath (e.g. Mac Catalyst build) — ignore build
# artifacts, but keep the tracked generic build-pattern examples (build/README.md)
build/*
!build/README.md
!build/build.config.example.json
!build/apply-branding.example.mjs

# native build artifacts (the ios/ and android/ projects are generated by `cap add`)
ios/App/Pods/
ios/App/build/
ios/DerivedData/
android/.gradle/
android/app/build/
android/build/
*.xcuserstate

# misc
.DS_Store
*.log

# Playwright MCP scratch (screenshots, snapshots, console logs)
.playwright-mcp/

# --- Private branded/signing overlay: never commit these ---
build.config.json
/assets/brand/
# Apple
*.p12
*.mobileprovision
*.cer
*.certSigningRequest
AuthKey_*.p8
# Android
*.keystore
*.jks
keystore.properties
# Generic secrets
.env
.env.*
*.pem
