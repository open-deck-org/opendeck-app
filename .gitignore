# dependencies
node_modules/

# vendored browser libs (regenerated by postinstall)
www/vendor/

# collected build outputs (binaries) — keep the folder's README, ignore artifacts
dist/*
!dist/README.md

# local xcodebuild derivedDataPath (e.g. Mac Catalyst build)
build/

# native build artifacts (the ios/ and android/ projects are generated by `cap add`)
ios/App/Pods/
ios/App/build/
ios/DerivedData/
android/.gradle/
android/app/build/
android/build/
*.xcuserstate

# misc
.DS_Store
*.log

# Playwright MCP scratch (screenshots, snapshots, console logs)
.playwright-mcp/
